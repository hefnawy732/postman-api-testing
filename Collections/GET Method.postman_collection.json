  "item": [
    {
      "name": "Success - (200 OK)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const data = pm.response.json()",
              "",
              "// Status code validation ",
              "pm.test(\"Status code is 200\", function() {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Response time check",
              "pm.test(\"Response time is under 2 seconds\", function() {",
              "pm.expect(pm.response.responseTime).to.be.below(2000);",
              "});",
              "",
              "// Response is not empty",
              "pm.test(\"Response has data\", function() {",
              "pm.expect(data).to.not.be.empty;",
              "});",
              "",
              "// Response returns an object",
              "pm.test(\"Response returns an object\", function() {",
              "   pm.expect(data).to.be.an(\"object\");",
              "});",
              "",
              "// Check mandatory fields and domain data types",
              "const users = data.users",
              "",
              "pm.test(\"Each user has required fields\", function() {",
              "    users.forEach(user => {",
              "        pm.expect(user).to.have.property(\"id\");",
              "        pm.expect(user.id).to.be.a(\"number\");",
              "",
              "        pm.expect(user).to.have.property(\"email\");",
              "        pm.expect(user.email).to.be.a(\"string\");",
              "    });",
              "});",
              "",
              "",
              "// No nullable values for ID",
              "pm.test(\"No unexpected null values\", function () {",
              "    users.forEach(user => {",
              "        pm.expect(user.id).to.not.be.null;",
              "    });",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{DummyJson_url}}/users?limit=1000",
          "host": [
            "{{DummyJson_url}}"
          ],
          "path": [
            "users"
          ],
          "query": [
            {
              "key": "limit",
              "value": "1000"
            }
          ]
        }
      },
